PORT=3000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://SEU-FRONTEND.exemplo.com,https://SEU-FRONTEND-*.vercel.app


# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=SEU_TOKEN_WHATSAPP
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# WHATSAPP_API_VERSION=v18.0

# Mercado Pago
MP_ACCESS_TOKEN=SEU_ACCESS_TOKEN_MERCADO_PAGO
MP_PUBLIC_KEY=SEU_PUBLIC_KEY_MERCADO_PAGO
MP_WEBHOOK_URL=https://SEU-BACKEND.exemplo.com/webhooks/mercadopago
# MP_API_BASE_URL=https://api.mercadopago.com

# Barber admin (usado para permitir cancelamento via barber-app)
BARBER_API_KEY=change-me

# Observabilidade
SLOW_REQUEST_MS=2000
SLOW_DB_MS=200

# Rate limit
# Em Cloud Run, prefira "none" ou um store distribuído externo.
RATE_LIMIT_STORE=none

# Fuso horário do sistema (default: America/Sao_Paulo)
APP_TIMEZONE=America/Sao_Paulo

# ---------------------------------------------------------------------------
# Notificações Push (Web Push / VAPID)
# ---------------------------------------------------------------------------
# Gere as chaves com: npx web-push generate-vapid-keys
# NUNCA coloque chaves reais neste arquivo de exemplo.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@barbearia.exemplo.com

# Rotina de lembretes
# PUSH_REMINDERS_ENABLED=false desliga o scheduler in-process (útil quando os
# lembretes são disparados por um cron externo via POST /api/push/run-reminders).
PUSH_REMINDERS_ENABLED=true
# Intervalo (segundos) entre execuções do scheduler in-process.
PUSH_REMINDER_INTERVAL_SECONDS=60
# Antecedência (minutos) de cada lembrete.
PUSH_REMINDER_BARBER_MINUTES=15
PUSH_REMINDER_CUSTOMER_MINUTES=60
PUSH_REMINDER_DAY_BEFORE_MINUTES=1440
# Chave para proteger o disparo manual/cron de lembretes (header x-cron-key).
# Se não definida, a rota aceita a BARBER_API_KEY (header x-barber-api-key).
PUSH_CRON_KEY=change-me
